---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="INSERT COIN">
  <main class="flex flex-col items-center justify-center min-h-screen px-4">
    <div class="text-center max-w-md">
      <h1 class="font-['Orbitron'] text-4xl font-black tracking-wider mb-2">
        <span class="text-neon-yellow">INSERT</span> <span class="text-neon-pink">COIN</span>
      </h1>
      <p class="text-text-secondary mb-12">
        ゲーセンに入るにはコインが必要だ
      </p>

      <a
        id="github-login"
        href="#"
        class="inline-flex items-center gap-3 px-8 py-4 bg-bg-surface border border-bg-raised rounded-lg hover:border-neon-yellow hover:shadow-[0_0_20px_rgba(255,230,0,0.2)] transition-all duration-300"
      >
        <svg class="w-5 h-5 text-text-primary" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        <span class="text-text-primary font-medium">GitHub でログイン</span>
      </a>

      <p class="text-text-muted text-xs mt-8">
        ログインすることで利用規約に同意したものとみなされます
      </p>
    </div>
  </main>
</Layout>

<script>
  import { createSupabaseBrowser } from '../../lib/supabase';

  const supabase = createSupabaseBrowser();

  // Redirect to home if already logged in
  const { data: { user: existingUser } } = await supabase.auth.getUser();
  if (existingUser) {
    window.location.replace('/home');
  }

  document.getElementById('github-login')?.addEventListener('click', async (e) => {
    e.preventDefault();
    const { error } = await supabase.auth.signInWithOAuth({
      provider: 'github',
      options: {
        redirectTo: `${window.location.origin}/auth/callback`,
      },
    });
    if (error) {
      // Display error in UI instead of console
      const msg = document.createElement('p');
      msg.className = 'text-neon-pink text-sm mt-4';
      msg.textContent = 'ログインに失敗しました。もう一度お試しください。';
      document.getElementById('github-login')?.parentElement?.appendChild(msg);
    }
  });
</script>
