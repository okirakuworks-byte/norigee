---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Loading...">
  <div class="flex items-center justify-center min-h-screen">
    <p class="font-['Orbitron'] text-text-muted animate-pulse">LOADING...</p>
  </div>
</Layout>

<script>
  import { createSupabaseBrowser } from '../../lib/supabase';

  const supabase = createSupabaseBrowser();

  // Implicit flow: tokens come in URL hash (#access_token=...)
  // PKCE flow: code comes in query string (?code=...)
  // Handle both cases

  const hashParams = new URLSearchParams(window.location.hash.substring(1));
  const queryParams = new URLSearchParams(window.location.search);

  const accessToken = hashParams.get('access_token');
  const code = queryParams.get('code');

  if (accessToken) {
    // Implicit flow — Supabase client auto-detects hash tokens
    // Just wait for the session to be set
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      window.location.replace('/home');
    } else {
      // Give it a moment to process
      setTimeout(async () => {
        const { data: { session: s } } = await supabase.auth.getSession();
        window.location.replace(s ? '/home' : '/auth/login?error=auth_failed');
      }, 1000);
    }
  } else if (code) {
    // PKCE flow
    const { error } = await supabase.auth.exchangeCodeForSession(code);
    window.location.replace(error ? '/auth/login?error=auth_failed' : '/home');
  } else {
    // No tokens or code — try checking session (might already be set by Supabase auto-detection)
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      window.location.replace('/home');
    } else {
      window.location.replace('/auth/login');
    }
  }
</script>
