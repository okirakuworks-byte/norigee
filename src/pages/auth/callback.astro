---
import Layout from '../../layouts/Layout.astro';
import { createSupabaseServer } from '../../lib/supabase';

const code = Astro.url.searchParams.get('code');

if (code) {
  const supabase = createSupabaseServer(Astro);
  const { data, error } = await supabase.auth.exchangeCodeForSession(code);

  if (error) {
    return Astro.redirect('/auth/login?error=auth_failed');
  }

  // Check if profile exists — redirect to setup if not
  if (data.user) {
    const { data: profile } = await supabase
      .from('profiles')
      .select('id')
      .eq('id', data.user.id)
      .maybeSingle();

    if (!profile) {
      return Astro.redirect('/profile/setup');
    }
  }

  return Astro.redirect('/home');
}

// No code in query params — fall through to client-side handling for hash tokens
---

<Layout title="Loading...">
  <div class="flex items-center justify-center min-h-screen">
    <p class="font-['Orbitron'] text-text-muted animate-pulse">LOADING...</p>
  </div>
</Layout>

<script>
  import { createSupabaseBrowser } from '../../lib/supabase';

  const supabase = createSupabaseBrowser();

  // Fallback: check if session was already set (e.g. hash fragment tokens)
  const hashParams = new URLSearchParams(window.location.hash.substring(1));
  const accessToken = hashParams.get('access_token');

  async function redirectWithProfileCheck() {
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) {
      window.location.replace('/auth/login?error=auth_failed');
      return;
    }
    // Check if profile exists
    const { data: profile } = await supabase
      .from('profiles')
      .select('id')
      .eq('id', user.id)
      .maybeSingle();

    window.location.replace(profile ? '/home' : '/profile/setup');
  }

  if (accessToken) {
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      await redirectWithProfileCheck();
    } else {
      setTimeout(async () => {
        const { data: { session: s } } = await supabase.auth.getSession();
        if (s) {
          await redirectWithProfileCheck();
        } else {
          window.location.replace('/auth/login?error=auth_failed');
        }
      }, 1000);
    }
  } else {
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      await redirectWithProfileCheck();
    } else {
      window.location.replace('/auth/login');
    }
  }
</script>
