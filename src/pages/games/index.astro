---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { supabase } from '../../lib/supabase';

// Fetch top scores per game for display
const { data: topScores } = await supabase
  .from('game_scores')
  .select('game_id, score, profiles!game_scores_user_id_fkey(display_name)')
  .order('score', { ascending: false })
  .limit(100);

// Build a map: gameId → { score, player }
const highScoreMap: Record<string, { score: number; player: string }> = {};
if (topScores) {
  for (const row of topScores as unknown as Array<{ game_id: string; score: number; profiles: { display_name: string } }>) {
    if (!highScoreMap[row.game_id]) {
      highScoreMap[row.game_id] = { score: row.score, player: row.profiles?.display_name ?? '?' };
    }
  }
}

