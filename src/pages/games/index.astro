---

<Layout title="ARCADE">
  <Header />

  <main class="max-w-5xl mx-auto px-4 py-8">
    <div class="text-center mb-10">
      <h1 class="font-['Orbitron'] text-3xl font-black tracking-wider mb-2">
        <span class="text-neon-yellow">GAME</span> <span class="text-neon-pink">CENTER</span>
      </h1>
      <p class="text-text-secondary text-sm">筐体を選べ。逃げ場はない。</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {cabinets.map((cab) => (
        <div class="group relative">
          {cab.href ? (
            <a href={cab.href} class="block">
              <div
                class="relative bg-bg-surface border border-bg-raised rounded-xl p-6 h-full transition-all duration-300 hover:border-current hover:shadow-[0_0_25px_var(--glow)]"
                style={`--glow: ${cab.glowColor}`}
              >
                <div class="text-4xl mb-4">{cab.icon}</div>
                <h2 class={`font-['Orbitron'] text-sm font-bold tracking-wider mb-1 ${cab.color}`}>
                  {cab.name}
                </h2>
                <p class="text-text-primary text-xs mb-3">{cab.subtitle}</p>
                <p class="text-text-secondary text-xs leading-relaxed mb-4">{cab.description}</p>
                <div class="flex items-center justify-between">
                  <span class="text-neon-yellow text-xs">{cab.difficulty}</span>
                  {highScoreMap[cab.id] ? (
                    <span class="font-['Share_Tech_Mono'] text-[10px] text-neon-cyan">
                      👑 {highScoreMap[cab.id].score} — {highScoreMap[cab.id].player}
                    </span>
                  ) : (
                    <span class="font-['Orbitron'] text-[10px] text-neon-cyan tracking-widest animate-pulse">
                      PRESS START
                    </span>
                  )}
                </div>
              </div>
            </a>
          ) : (
            <div
              class="relative bg-bg-surface/50 border border-bg-raised/50 rounded-xl p-6 h-full opacity-70"
            >
              <div class="text-4xl mb-4 grayscale">{cab.icon}</div>
              <h2 class={`font-['Orbitron'] text-sm font-bold tracking-wider mb-1 text-text-muted`}>
                {cab.name}
              </h2>
              <p class="text-text-muted text-xs mb-3">{cab.subtitle}</p>
              <p class="text-text-muted text-xs leading-relaxed mb-4">{cab.description}</p>
              <div class="flex items-center justify-between">
                <span class="text-text-muted text-xs">{cab.difficulty}</span>
                <span class="font-['Orbitron'] text-[10px] text-text-muted tracking-widest">
                  COMING SOON
                </span>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <p class="text-text-muted text-xs">
        新筐体は順次解禁。焦るな、どうせ全部無理ゲーだ。
      </p>
    </div>
  </main>
</Layout>

<script>
  import { requireProfile } from '../../lib/authGuard';
  requireProfile();
</script>
