---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import UserManager from '../../components/admin/UserManager';
---

<Layout title="ADMIN - Users">
  <Header />
  <main class="max-w-5xl mx-auto px-4 py-6">
    <div class="flex items-center justify-between mb-6">
      <h1 class="font-['Orbitron'] text-xl font-bold">
        <span class="text-neon-pink">ADMIN</span> PANEL
      </h1>
      <div class="flex gap-4 text-xs">
        <a href="/admin" class="text-text-muted hover:text-text-primary transition-colors">お題管理</a>
        <a href="/admin/users" class="text-neon-yellow border-b border-neon-yellow pb-1">ユーザー</a>
        <a href="/admin/moderation" class="text-text-muted hover:text-text-primary transition-colors">モデレーション</a>
      </div>
    </div>
    <UserManager client:load />
  </main>
</Layout>
