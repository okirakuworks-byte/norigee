---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import PostDetailWrapper from '../../components/PostDetailWrapper';
---

<Layout title="投稿詳細">
  <Header />

  <div id="auth-loading" class="hidden flex items-center justify-center py-20">
    <p class="font-['Orbitron'] text-text-muted text-sm animate-pulse tracking-widest">LOADING...</p>
  </div>

  <main class="max-w-5xl mx-auto px-4 py-6" style="opacity:0;transition:opacity 0.2s">
    <PostDetailWrapper client:load />
  </main>
</Layout>

<script>
  import { requireProfile } from '../../lib/authGuard';
  requireProfile();
</script>
