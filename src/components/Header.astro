---
import { createSupabaseServer } from '../lib/supabase';

const supabase = createSupabaseServer(Astro);
const { data: { user } } = await supabase.auth.getUser();

let profile = null;
if (user) {
  const { data } = await supabase
    .from('profiles')
    .select('display_name, avatar_url')
    .eq('id', user.id)
    .maybeSingle();
  profile = data;
}
---

<header class="sticky top-0 z-50 bg-bg-deep/90 backdrop-blur-md border-b border-bg-raised">
  <div class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href="/home" class="font-['Orbitron'] text-xl font-black tracking-wider">
      <span class="text-neon-yellow">NORI</span><span class="text-neon-pink">GEE</span>
    </a>

    <nav class="flex items-center gap-4">
      <a href="/home" class="text-text-secondary hover:text-text-primary text-sm transition-colors">
        FEED
      </a>
      <a href="/games" class="text-text-secondary hover:text-neon-cyan text-sm transition-colors">
        GAMES
      </a>

      {user ? (
        <>
          <span id="credit-display" class="px-3 py-1.5 bg-bg-surface border border-neon-yellow/50 text-neon-yellow font-['Share_Tech_Mono'] text-xs font-bold rounded">
            ¥---
          </span>
          <a id="lottery-btn" href="/lottery" class="relative text-text-muted hover:text-neon-pink transition-colors" title="くじ引き">
            🎰
            <span id="lottery-badge" class="hidden absolute -top-1 -right-1 w-3 h-3 bg-neon-pink rounded-full animate-pulse"></span>
          </a>
          <button id="notif-btn" class="relative text-text-muted hover:text-neon-yellow transition-colors" title="通知">
            🔔
            <span id="notif-badge" class="hidden absolute -top-1 -right-1 w-4 h-4 bg-neon-pink text-bg-deep text-[8px] font-bold rounded-full flex items-center justify-center">0</span>
          </button>
          <div id="notif-dropdown" class="hidden absolute right-16 top-12 w-72 bg-bg-surface border border-bg-raised rounded-xl shadow-lg z-50 max-h-80 overflow-y-auto">
            <div class="px-3 py-2 border-b border-bg-raised flex items-center justify-between">
              <span class="font-['Orbitron'] text-[10px] text-text-muted">NOTIFICATIONS</span>
              <button id="notif-read-all" class="text-neon-cyan text-[10px] hover:underline">全て既読</button>
            </div>
            <div id="notif-list" class="divide-y divide-bg-raised"></div>
            <div id="notif-empty" class="hidden px-3 py-4 text-center text-text-muted text-xs">通知なし</div>
          </div>
          <div class="flex items-center gap-2">
            {profile?.avatar_url ? (
              <img src={profile.avatar_url} alt="" class="w-7 h-7 rounded-full" />
            ) : (
              <div class="w-7 h-7 rounded-full bg-bg-raised flex items-center justify-center text-xs text-text-muted">?</div>
            )}
            <span class="text-text-secondary text-xs hidden md:inline">{profile?.display_name ?? 'Player'}</span>
            <button id="logout-btn" class="text-text-muted hover:text-neon-pink text-xs transition-colors ml-1" title="ログアウト">✕</button>
          </div>
        </>
      ) : (
        <a href="/auth/login" class="px-4 py-1.5 bg-neon-yellow text-bg-deep font-['Orbitron'] text-xs font-bold rounded hover:shadow-[0_0_15px_rgba(255,230,0,0.4)] transition-shadow">
          INSERT COIN
        </a>
      )}
    </nav>
  </div>
</header>

<script>
  import { createSupabaseBrowser } from '../lib/supabase';
  import { supabase } from '../lib/supabase';

  // Logout
  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    const sb = createSupabaseBrowser();
    await sb.auth.signOut();
    window.location.href = '/auth/login';
  });

  // Notifications
  const badge = document.getElementById('notif-badge');
  const dropdown = document.getElementById('notif-dropdown');
  const listEl = document.getElementById('notif-list');
  const emptyEl = document.getElementById('notif-empty');
  const btn = document.getElementById('notif-btn');
  const readAllBtn = document.getElementById('notif-read-all');

  function renderNotification(n: { type: string; is_read: boolean; created_at: string; profiles?: { display_name: string } }) {
    const div = document.createElement('div');
    div.className = `px-3 py-2 ${n.is_read ? 'opacity-50' : ''} hover:bg-bg-raised/50`;
    const actor = n.profiles?.display_name ?? '?';
    const typeLabel = n.type === 'resonance' ? '🤝 共鳴' : n.type === 'comment' ? '💬 コメント' : '🔔';
    const time = new Date(n.created_at).toLocaleTimeString('ja-JP', { hour: '2-digit', minute: '2-digit' });
    const p1 = document.createElement('p');
    p1.className = 'text-xs text-text-primary';
    p1.textContent = `${typeLabel} ${actor}`;
    const p2 = document.createElement('p');
    p2.className = 'text-[10px] text-text-muted';
    p2.textContent = time;
    div.appendChild(p1);
    div.appendChild(p2);
    return div;
  }

  async function loadNotifications() {
    const { data: { user } } = await supabase.auth.getUser();
    if (!user || !listEl || !badge || !emptyEl) return;

    const { data: notifs } = await supabase
      .from('notifications')
      .select('id, type, is_read, created_at, actor_id, post_id, profiles!notifications_actor_id_fkey(display_name)')
      .eq('recipient_id', user.id)
      .order('created_at', { ascending: false })
      .limit(20);

    if (!notifs) return;

    const unread = notifs.filter((n: Record<string, unknown>) => !n.is_read).length;
    if (unread > 0) {
      badge.textContent = String(unread);
      badge.classList.remove('hidden');
    } else {
      badge.classList.add('hidden');
    }

    listEl.replaceChildren();
    if (notifs.length === 0) {
      emptyEl.classList.remove('hidden');
      return;
    }
    emptyEl.classList.add('hidden');
    for (const n of notifs) {
      listEl.appendChild(renderNotification(n as unknown as Parameters<typeof renderNotification>[0]));
    }
  }

  btn?.addEventListener('click', (e) => { e.stopPropagation(); dropdown?.classList.toggle('hidden'); loadNotifications(); });
  document.addEventListener('click', () => dropdown?.classList.add('hidden'));
  dropdown?.addEventListener('click', (e) => e.stopPropagation());

  readAllBtn?.addEventListener('click', async () => {
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) return;
    await supabase.from('notifications').update({ is_read: true }).eq('recipient_id', user.id).eq('is_read', false);
    loadNotifications();
  });

  const { data: { user: currentUser } } = await supabase.auth.getUser();
  if (currentUser) {
    supabase.channel('my-notifications')
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'notifications', filter: `recipient_id=eq.${currentUser.id}` }, () => loadNotifications())
      .subscribe();
  }
  loadNotifications();

  // Wallet balance
  async function loadBalance() {
    const { data: { user: u } } = await supabase.auth.getUser();
    if (!u) return;
    const { data: wallet } = await supabase
      .from('wallets')
      .select('balance')
      .eq('user_id', u.id)
      .maybeSingle();
    const creditEl = document.getElementById('credit-display');
    if (creditEl && wallet) {
      creditEl.textContent = `\u00A5${wallet.balance}`;
      if (wallet.balance <= 100) {
        creditEl.classList.remove('text-neon-yellow', 'border-neon-yellow');
        creditEl.classList.add('text-neon-pink', 'border-neon-pink');
      }
    }
  }
  loadBalance();

  // Auto-claim login bonus
  async function claimLogin() {
    const { data: { user: u } } = await supabase.auth.getUser();
    if (!u) return;
    const today = new Date().toISOString().slice(0, 10);
    const { data: counter } = await supabase
      .from('daily_action_counters')
      .select('login_claimed')
      .eq('user_id', u.id)
      .eq('action_date', today)
      .maybeSingle();
    if (counter?.login_claimed) return;
    await supabase.from('daily_action_counters').upsert(
      { user_id: u.id, action_date: today, login_claimed: true },
      { onConflict: 'user_id,action_date' }
    );
    const { data: w } = await supabase.from('wallets').select('balance').eq('user_id', u.id).single();
    if (!w) return;
    const nb = w.balance + 100;
    await supabase.from('wallets').update({ balance: nb, updated_at: new Date().toISOString() }).eq('user_id', u.id);
    await supabase.from('coin_transactions').insert({
      user_id: u.id, amount: 100, balance_after: nb, tx_type: 'daily_login', description: 'デイリーログインボーナス \u00A5100'
    });
    loadBalance();
  }
  claimLogin();

  // Lottery badge
  async function checkLottery() {
    const { data: { user: u } } = await supabase.auth.getUser();
    if (!u) return;
    const today = new Date().toISOString().slice(0, 10);
    const { data: counter } = await supabase
      .from('daily_action_counters')
      .select('lottery_drawn')
      .eq('user_id', u.id)
      .eq('action_date', today)
      .maybeSingle();
    const lotteryBadge = document.getElementById('lottery-badge');
    if (lotteryBadge && (!counter || !counter.lottery_drawn)) {
      lotteryBadge.classList.remove('hidden');
    }
  }
  checkLottery();
</script>
