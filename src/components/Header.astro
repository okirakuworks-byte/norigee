---
---

<header class="sticky top-0 z-50 bg-bg-deep/90 backdrop-blur-md border-b border-bg-raised">
  <div class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href="/home" class="font-['Orbitron'] text-xl font-black tracking-wider">
      <span class="text-neon-yellow">NORI</span><span class="text-neon-pink">GEE</span>
    </a>

    <nav class="flex items-center gap-4">
      <a href="/home" class="hidden md:inline text-text-secondary hover:text-text-primary text-sm transition-colors">
        FEED
      </a>
      <a href="/games" class="hidden md:inline text-text-secondary hover:text-neon-cyan text-sm transition-colors">
        GAMES
      </a>
      <a id="admin-link" href="/admin" class="hidden text-neon-pink hover:text-neon-pink/80 text-sm transition-colors font-bold">
        ADMIN
      </a>

      {/* Default: logged-out state */}
      <a id="login-link" href="/auth/login" class="px-4 py-1.5 bg-neon-yellow text-bg-deep font-['Orbitron'] text-xs font-bold rounded hover:shadow-[0_0_15px_rgba(255,230,0,0.4)] transition-shadow">
        LOGIN
      </a>

      {/* Logged-in UI — hidden by default, revealed by client-side script */}
      <div id="user-nav" class="hidden contents">
        <span id="credit-display" class="px-3 py-1.5 bg-bg-surface border border-neon-yellow/50 text-neon-yellow font-['Share_Tech_Mono'] text-xs font-bold rounded">
          ¥---
        </span>
        <a id="lottery-btn" href="/lottery" class="relative text-text-muted hover:text-neon-pink transition-colors" title="くじ引き">
          🎰
          <span id="lottery-badge" class="hidden absolute -top-1 -right-1 w-3 h-3 bg-neon-pink rounded-full animate-pulse"></span>
        </a>
        <button id="notif-btn" class="relative text-text-muted hover:text-neon-yellow transition-colors" title="通知">
          🔔
          <span id="notif-badge" class="hidden absolute -top-1 -right-1 w-4 h-4 bg-neon-pink text-bg-deep text-[8px] font-bold rounded-full flex items-center justify-center">0</span>
        </button>
        <div id="notif-dropdown" class="hidden absolute right-0 top-12 w-72 max-w-[calc(100vw-2rem)] bg-bg-surface border border-bg-raised rounded-xl shadow-lg z-50 max-h-80 overflow-y-auto">
          <div class="px-3 py-2 border-b border-bg-raised flex items-center justify-between">
            <span class="font-['Orbitron'] text-[10px] text-text-muted">NOTIFICATIONS</span>
            <button id="notif-read-all" class="text-neon-cyan text-[10px] hover:underline">全て既読</button>
          </div>
          <div id="notif-list" class="divide-y divide-bg-raised"></div>
          <div id="notif-empty" class="hidden px-3 py-4 text-center text-text-muted text-xs">通知なし</div>
        </div>
        <div class="flex items-center gap-2">
          <a href="/profile/edit" class="flex items-center gap-2 hover:opacity-80 transition-opacity" title="プロフィール編集">
            <img id="user-avatar" src="" alt="" class="hidden w-7 h-7 rounded-full" />
            <div id="user-avatar-emoji" class="w-7 h-7 rounded-full bg-bg-raised flex items-center justify-center text-sm">?</div>
            <span id="user-display-name" class="text-text-secondary text-xs hidden md:inline">Player</span>
          </a>
          <button id="logout-btn" class="text-text-muted hover:text-neon-pink hover:bg-neon-pink/10 text-xs transition-colors ml-1 px-1.5 py-1 rounded" title="ログアウト" aria-label="ログアウト">✕</button>
        </div>
      </div>
    </nav>
  </div>
</header>

{/* Mobile bottom nav */}
<nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-bg-deep/95 backdrop-blur-md border-t border-bg-raised">
  <div class="flex items-center justify-around h-12" id="mobile-nav">
    <a href="/home" data-nav="home" class="flex flex-col items-center gap-0.5 text-text-muted transition-colors">
      <span class="text-base">🏠</span>
      <span class="text-[8px] font-['Orbitron']">FEED</span>
    </a>
    <a href="/games" data-nav="games" class="flex flex-col items-center gap-0.5 text-text-muted transition-colors">
      <span class="text-base">🕹️</span>
      <span class="text-[8px] font-['Orbitron']">GAMES</span>
    </a>
    <a href="/posts/new" data-nav="posts" class="flex flex-col items-center gap-0.5 text-text-muted transition-colors">
      <span class="text-lg">⊕</span>
      <span class="text-[8px] font-['Orbitron']">POST</span>
    </a>
    <a href="/lottery" data-nav="lottery" class="flex flex-col items-center gap-0.5 text-text-muted transition-colors">
      <span class="text-base">🎰</span>
      <span class="text-[8px] font-['Orbitron']">GACHA</span>
    </a>
    <a href="/profile/edit" data-nav="profile" class="flex flex-col items-center gap-0.5 text-text-muted transition-colors">
      <span class="text-base">👤</span>
      <span class="text-[8px] font-['Orbitron']">ME</span>
    </a>
  </div>
</nav>

<script>
  // Mobile nav active state
  const path = window.location.pathname;
  const navMap: Record<string, string> = {
    '/home': 'home',
    '/games': 'games',
    '/posts/new': 'posts',
    '/lottery': 'lottery',
    '/profile/edit': 'profile',
    '/profile/setup': 'profile',
  };
  const activeNav = Object.entries(navMap).find(([prefix]) => path.startsWith(prefix))?.[1];
  if (activeNav) {
    const activeEl = document.querySelector(`[data-nav="${activeNav}"]`);
    if (activeEl) {
      activeEl.classList.remove('text-text-muted');
      const colors: Record<string, string> = {
        home: 'text-neon-yellow',
        games: 'text-neon-cyan',
        posts: 'text-neon-yellow',
        lottery: 'text-neon-pink',
        profile: 'text-neon-cyan',
      };
      activeEl.classList.add(colors[activeNav] ?? 'text-neon-yellow');
    }
  }
</script>

<script>
  import { createSupabaseBrowser } from '../lib/supabase';
  import { claimLoginBonus } from '../lib/wallet';
  import type { User } from '@supabase/supabase-js';

  const supabase = createSupabaseBrowser();

  // ============================================
  // Single getUser() call — cached for all functions
  // ============================================
  let cachedUser: User | null = null;

  async function getAuthUser(): Promise<User | null> {
    if (cachedUser) return cachedUser;
    const { data: { user } } = await supabase.auth.getUser();
    cachedUser = user;
    return user;
  }

  // ============================================
  // Init header UI
  // ============================================
  async function initHeader(user: User) {
    const { data: profile } = await supabase
      .from('profiles')
      .select('display_name, avatar_url, avatar_emoji')
      .eq('id', user.id)
      .maybeSingle();

    if (!profile) {
      window.location.replace('/profile/setup');
      return;
    }

    document.getElementById('login-link')?.classList.add('hidden');
    const userNav = document.getElementById('user-nav');
    if (userNav) {
      userNav.classList.remove('hidden');
      userNav.classList.add('flex', 'items-center', 'gap-4');
    }

    const avatarImg = document.getElementById('user-avatar') as HTMLImageElement | null;
    const avatarEmoji = document.getElementById('user-avatar-emoji');
    if (profile.avatar_url) {
      if (avatarImg) {
        avatarImg.src = profile.avatar_url;
        avatarImg.classList.remove('hidden');
      }
      avatarEmoji?.classList.add('hidden');
    } else if (profile.avatar_emoji && avatarEmoji) {
      avatarEmoji.textContent = profile.avatar_emoji;
    }

    const nameEl = document.getElementById('user-display-name');
    if (nameEl) {
      nameEl.textContent = profile.display_name;
    }

    const { data: admin } = await supabase
      .from('admin_users')
      .select('user_id')
      .eq('user_id', user.id)
      .maybeSingle();

    if (admin) {
      document.getElementById('admin-link')?.classList.remove('hidden');
    }
  }

  // Logout
  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/auth/login';
  });

  // ============================================
  // Notifications
  // ============================================
  const badge = document.getElementById('notif-badge');
  const dropdown = document.getElementById('notif-dropdown');
  const listEl = document.getElementById('notif-list');
  const emptyEl = document.getElementById('notif-empty');
  const btn = document.getElementById('notif-btn');
  const readAllBtn = document.getElementById('notif-read-all');

  function renderNotification(n: { type: string; is_read: boolean; created_at: string; post_id?: number; profiles?: { display_name: string } }) {
    const wrapper = n.post_id
      ? document.createElement('a') as HTMLAnchorElement
      : document.createElement('div');
    if (n.post_id && wrapper instanceof HTMLAnchorElement) {
      wrapper.href = `/posts/view?id=${n.post_id}`;
    }
    wrapper.className = `block px-3 py-2 ${n.is_read ? 'opacity-50' : ''} hover:bg-bg-raised/50 cursor-pointer transition-colors`;
    const actor = n.profiles?.display_name ?? '?';
    const typeLabel = n.type === 'resonance' ? '🤝 共鳴' : n.type === 'comment' ? '💬 コメント' : '🔔';
    const time = new Date(n.created_at).toLocaleTimeString('ja-JP', { hour: '2-digit', minute: '2-digit' });
    const p1 = document.createElement('p');
    p1.className = 'text-xs text-text-primary';
    p1.textContent = `${typeLabel} ${actor}`;
    const p2 = document.createElement('p');
    p2.className = 'text-[10px] text-text-muted';
    p2.textContent = time;
    wrapper.appendChild(p1);
    wrapper.appendChild(p2);
    return wrapper;
  }

  async function loadNotifications(user: User) {
    if (!listEl || !badge || !emptyEl) return;

    const { data: notifs } = await supabase
      .from('notifications')
      .select('id, type, is_read, created_at, actor_id, post_id, profiles!notifications_actor_id_fkey(display_name)')
      .eq('recipient_id', user.id)
      .order('created_at', { ascending: false })
      .limit(20);

    if (!notifs) return;

    const unread = notifs.filter((n: Record<string, unknown>) => !n.is_read).length;
    if (unread > 0) {
      badge.textContent = String(unread);
      badge.classList.remove('hidden');
    } else {
      badge.classList.add('hidden');
    }

    listEl.replaceChildren();
    if (notifs.length === 0) {
      emptyEl.classList.remove('hidden');
      return;
    }
    emptyEl.classList.add('hidden');
    for (const n of notifs) {
      const notif = n as unknown as Parameters<typeof renderNotification>[0];
      listEl.appendChild(renderNotification(notif));
    }
  }

  btn?.addEventListener('click', async (e) => {
    e.stopPropagation();
    dropdown?.classList.toggle('hidden');
    const user = await getAuthUser();
    if (user) loadNotifications(user);
  });
  document.addEventListener('click', () => dropdown?.classList.add('hidden'));
  dropdown?.addEventListener('click', (e) => e.stopPropagation());

  readAllBtn?.addEventListener('click', async () => {
    const user = await getAuthUser();
    if (!user) return;
    await supabase.from('notifications').update({ is_read: true }).eq('recipient_id', user.id).eq('is_read', false);
    loadNotifications(user);
  });

  // ============================================
  // Wallet balance
  // ============================================
  async function loadBalance(user: User) {
    const { data: wallet } = await supabase
      .from('wallets')
      .select('balance')
      .eq('user_id', user.id)
      .maybeSingle();
    const creditEl = document.getElementById('credit-display');
    if (creditEl && wallet) {
      creditEl.textContent = `\u00A5${wallet.balance}`;
      if (wallet.balance <= 100) {
        creditEl.classList.remove('text-neon-yellow', 'border-neon-yellow');
        creditEl.classList.add('text-neon-pink', 'border-neon-pink');
      }
    }
  }

  // ============================================
  // Auto-claim login bonus (via wallet.ts)
  // ============================================
  async function claimLogin(user: User) {
    try {
      const result = await claimLoginBonus();
      if (result.claimed) {
        loadBalance(user);
      }
    } catch {
      // Silently fail — login bonus is non-critical
    }
  }

  // ============================================
  // Lottery badge
  // ============================================
  async function checkLottery(user: User) {
    const today = new Date().toISOString().slice(0, 10);
    const { data: counter } = await supabase
      .from('daily_action_counters')
      .select('lottery_drawn')
      .eq('user_id', user.id)
      .eq('action_date', today)
      .maybeSingle();
    const lotteryBadge = document.getElementById('lottery-badge');
    if (lotteryBadge && (!counter || !counter.lottery_drawn)) {
      lotteryBadge.classList.remove('hidden');
    }
  }

  // ============================================
  // Bootstrap: single getUser() → run all init
  // ============================================
  async function bootstrap() {
    const user = await getAuthUser();
    if (!user) return;

    await initHeader(user);
    loadNotifications(user);
    loadBalance(user);
    claimLogin(user);
    checkLottery(user);

    // Realtime notifications subscription
    supabase.channel('my-notifications')
      .on('postgres_changes', {
        event: 'INSERT',
        schema: 'public',
        table: 'notifications',
        filter: `recipient_id=eq.${user.id}`,
      }, () => loadNotifications(user))
      .subscribe();
  }

  bootstrap();
</script>
